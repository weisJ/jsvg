<?xml version="1.0" encoding="UTF-8"?>

<?import com.github.weisj.jsvg.ui.jfx.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="800" prefWidth="1200.0" xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.github.weisj.jsvg.renderer.jfx.viewer.FXTestViewerController">
    <center>
        <HBox BorderPane.alignment="CENTER">
            <VBox HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER">
                    <Label alignment="CENTER" text="AWT (Reference)" textAlignment="CENTER">
                        <font>
                            <Font name="System Bold" size="14.0"/>
                        </font>
                    </Label>
                </HBox>
                <ScrollPane fx:id="scrollPaneAWT" fitToHeight="true" fitToWidth="true" pannable="true"
                            VBox.vgrow="ALWAYS">
                    <StackPane>
                        <FXSVGCanvas fx:id="svgCanvasAWT"/>
                    </StackPane>
                </ScrollPane>
            </VBox>
            <VBox HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER">
                    <Label alignment="CENTER" text="JavaFX" textAlignment="CENTER">
                        <font>
                            <Font name="System Bold" size="14.0"/>
                        </font>
                    </Label>
                </HBox>
                <ScrollPane fx:id="scrollPaneJFX" fitToHeight="true" fitToWidth="true" pannable="true"
                            VBox.vgrow="ALWAYS">
                    <StackPane>
                        <FXSVGCanvas fx:id="svgCanvasJFX"/>
                    </StackPane>
                </ScrollPane>
            </VBox>
        </HBox>
    </center>
    <top>
        <ToolBar BorderPane.alignment="CENTER">
            <items>
                <ComboBox fx:id="comboBoxSVGDocument" prefWidth="400.0"/>
                <Button layoutX="414.0" layoutY="10.0" mnemonicParsing="false" onAction="#previousSVG" text="Prev"/>
                <Button layoutX="414.0" layoutY="10.0" mnemonicParsing="false" onAction="#nextSVG" text="Next"/>
                <Button mnemonicParsing="false" onAction="#refreshCanvas" text="Refresh Canvas"/>
                <CheckBox fx:id="checkBoxShowTransparentPattern" text="Show Transparent Pattern"/>
            </items>
        </ToolBar>
    </top>
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="8"
              style="-fx-padding: 4 8 4 8; -fx-background-color: #f4f4f4; -fx-border-color: #cccccc; -fx-border-width: 1 0 0 0;"
              BorderPane.alignment="CENTER">
            <Button fx:id="buttonPlayPause" mnemonicParsing="false" onAction="#togglePlayPause" text="Pause"/>
            <Button mnemonicParsing="false" onAction="#restartAnimation" text="Restart"/>
        </HBox>
    </bottom>
</BorderPane>
